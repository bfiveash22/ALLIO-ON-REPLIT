generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/peptide_chat_app/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(cuid())
  email            String           @unique
  name             String?
  password         String
  isAdmin          Boolean          @default(false)
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  conversations    Conversation[]
  ivConversations  IVConversation[]
  imConversations  IMConversation[]
}

model Peptide {
  id              String         @id @default(cuid())
  name            String         @unique
  discoveryYear   String
  era             String
  description     String
  therapeuticUses String[]
  dosageInfo      String
  personaTrait    String
  imageUrl        String?
  createdAt       DateTime       @default(now())
  conversations   Conversation[]
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  peptideId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  peptide   Peptide   @relation(fields: [peptideId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
  messages  Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

// IV Therapy Models
model IVTherapy {
  id              String            @id @default(cuid())
  name            String            @unique
  category        String            // e.g., "Detox", "Energy", "Anti-Aging", "Immune Support"
  description     String
  benefits        String[]
  dosageRange     String
  dilution        String
  infusionTime    String
  frequency       String
  phases          String            // JSON string for treatment phases
  monitoring      String            // Monitoring requirements
  precautions     String            // Contraindications and cautions
  adjuncts        String            // Compatible adjunct therapies
  notes           String            // Clinical notes
  personaTrait    String            // AI personality trait
  createdAt       DateTime          @default(now())
  conversations   IVConversation[]
}

model IVConversation {
  id          String      @id @default(cuid())
  userId      String
  ivTherapyId String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  ivTherapy   IVTherapy   @relation(fields: [ivTherapyId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
  messages    IVMessage[]

  @@unique([userId, ivTherapyId])
}

model IVMessage {
  id               String         @id @default(cuid())
  ivConversationId String
  role             String
  content          String
  createdAt        DateTime       @default(now())
  ivConversation   IVConversation @relation(fields: [ivConversationId], references: [id], onDelete: Cascade)
}

// IM (Intramuscular) Therapy Models
model IMTherapy {
  id              String            @id @default(cuid())
  name            String            @unique
  category        String            // e.g., "Fat Dissolving", "Energy", "Anti-Aging"
  description     String
  benefits        String[]
  dosageRange     String
  reconstitution  String            // How to prepare/mix
  injectionSite   String            // Recommended injection sites
  injectionVolume String            // Volume per injection
  frequency       String
  phases          String            // JSON string for treatment phases
  monitoring      String            // Monitoring requirements
  precautions     String            // Contraindications and cautions
  storage         String            // Storage requirements
  notes           String            // Clinical notes
  personaTrait    String            // AI personality trait
  createdAt       DateTime          @default(now())
  conversations   IMConversation[]
}

model IMConversation {
  id          String      @id @default(cuid())
  userId      String
  imTherapyId String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  imTherapy   IMTherapy   @relation(fields: [imTherapyId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
  messages    IMMessage[]

  @@unique([userId, imTherapyId])
}

model IMMessage {
  id               String         @id @default(cuid())
  imConversationId String
  role             String
  content          String
  createdAt        DateTime       @default(now())
  imConversation   IMConversation @relation(fields: [imConversationId], references: [id], onDelete: Cascade)
}
