modules = ["nodejs-24", "postgresql-16"]

  [[artifacts]]
  id = "artifacts/api-server"

  [[artifacts]]
  id = "artifacts/ffpma"

  [deployment]
  router = "application"
  deploymentTarget = "autoscale"
  build = ["pnpm", "run", "build"]
  run = ["node", "artifacts/api-server/dist/index.cjs"]

  [deployment.postBuild]
  args = ["pnpm", "store", "prune"]
  env = { "CI" = "true" }

  [workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 pnpm --filter @workspace/api-server run dev & PORT=5173 pnpm --filter @workspace/ffpma run dev & wait"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

  [agent]
  stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0", "google-drive:1.0.0", "onedrive:1.0.0"]

  [postMerge]
  path = "scripts/post-merge.sh"
  timeoutMs = 60000

  [userenv]

  [userenv.shared]
WP_SITE_URL = "https://www.forgottenformula.com"
  WP_USERNAME = "blake"
  ENABLE_SCHEDULERS = "true"
  SIGNNOW_EMAIL = "blake@forgottenformula.com"
  RUPA_USERNAME = "blake@forgottenformula.com"
  PREVIEW_TOKEN_SECRET = "4175182e27d318e22d3b9d91599f0cb0fb1ed2ab88099908978f4cf97f4932c5"
  TELEGRAM_CHAT_ID = ""
OPENCLAW_WEBHOOK_URL = "http://vm93616.vpsone.xyz:8889/openclaw/receive"

  [nix]
  channel = "stable-25_05"
packages = ["alsa-lib", "at-spi2-atk", "cairo", "cups", "dbus", "expat", "gitFull", "glib", "gtk3", "libdrm", "libxkbcommon", "mesa", "mesa_glu", "nspr", "nss", "pango", "playwright-driver", "xorg.libX11", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXext", "xorg.libXfixes", "xorg.libXrandr", "xorg.libxcb", "imagemagick"]
  